{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "allowJs": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2016",
    "types": ["jest", "node"]
  },
  "files": ["src/polyfills.ts"],
  "include": ["src/**/*.spec.ts", "src/**/*.mock.ts", "src/**/*.d.ts", "src/setup-jest.ts", "src/test-config.helper.ts"]
}

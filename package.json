{
  "name": "ng-x-rocket-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "build": "npm run write:env -s && nx build ng-x-rocket --configuration production",
    "start": "npm run write:env -s && nx serve ng-x-rocket",
    "serve:sw": "npm run build -s && npx http-server ./dist/apps/ng-x-rocket/browser -p 4200",
    "lint": "nx lint ng-x-rocket && stylelint \"apps/ng-x-rocket/src/**/*.scss\" --syntax scss && htmlhint \"apps/ng-x-rocket/src\" --config .htmlhintrc",
    "test": "npm run write:env -s && nx test ng-x-rocket",
    "test:ci": "npm run write:env -s && npm run lint -s && nx test ng-x-rocket --configuration=ci",
    "e2e": "npm run write:env -s && nx e2e ng-x-rocket-e2e",
    "translations:extract": "ngx-translate-extract --input ./apps/ng-x-rocket/src --output ./apps/ng-x-rocket/src/translations/template.json --format=json --clean --sort",
    "docs": "hads ./docs -o",
    "write:env": "ngx-scripts env npm_package_version --out apps/ng-x-rocket/src/environments/.env.ts",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "generate": "nx generate"
  },
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/localize": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@angular/service-worker": "^20.3.18",
    "@fortawesome/fontawesome-free": "^5.15.1",
    "@ng-bootstrap/ng-bootstrap": "^19.0.1",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "rxjs": "^6.6.3",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^20.0.0",
    "@angular-devkit/build-angular": "^20.3.20",
    "@angular-devkit/core": "^20.3.20",
    "@angular-devkit/schematics": "^20.3.20",
    "@angular/cli": "^20.3.20",
    "@angular/compiler-cli": "^20.3.18",
    "@angular/language-service": "^20.3.18",
    "@biesbjerg/ngx-translate-extract": "^7.0.3",
    "@biesbjerg/ngx-translate-extract-marker": "^1.0.0",
    "@ngx-rocket/scripts": "^5.0.0",
    "@nx/angular": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@schematics/angular": "^20.3.20",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/jasmine": "^3.6.2",
    "@types/jasminewd2": "^2.0.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "angular-eslint": "^20.7.0",
    "eslint": "^9.39.4",
    "hads": "^3.0.0",
    "htmlhint": "^0.14.2",
    "https-proxy-agent": "^5.0.0",
    "husky": "^4.3.6",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~6.0.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.6.0",
    "nx": "22.5.4",
    "prettier": "~3.6.2",
    "pretty-quick": "^3.1.0",
    "protractor": "~7.0.0",
    "stylelint": "~13.8.0",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-recommended-scss": "~4.2.0",
    "stylelint-config-standard": "~20.0.0",
    "stylelint-scss": "~3.18.0",
    "ts-node": "^9.1.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.0"
  },
  "prettier": {
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.scss",
        "options": {
          "singleQuote": false
        }
      }
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "nx": {}
}

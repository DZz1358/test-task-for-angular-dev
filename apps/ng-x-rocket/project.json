{
  "name": "ng-x-rocket",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "generators": {
    "@schematics/angular:component": {
      "style": "scss"
    }
  },
  "sourceRoot": "apps/ng-x-rocket/src",
  "prefix": "app",
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "options": {
        "outputPath": {
          "base": "dist/apps/ng-x-rocket"
        },
        "index": "apps/ng-x-rocket/src/index.html",
        "polyfills": ["@angular/localize/init", "apps/ng-x-rocket/src/polyfills.ts"],
        "tsConfig": "apps/ng-x-rocket/tsconfig.app.json",
        "assets": [
          "apps/ng-x-rocket/src/favicon.ico",
          "apps/ng-x-rocket/src/apple-touch-icon.png",
          "apps/ng-x-rocket/src/robots.txt",
          "apps/ng-x-rocket/src/manifest.webmanifest",
          "apps/ng-x-rocket/src/assets"
        ],
        "styles": [
          "node_modules/@fortawesome/fontawesome-free/css/all.min.css",
          "apps/ng-x-rocket/src/main.scss",
          "node_modules/@angular/material/prebuilt-themes/indigo-pink.css"
        ],
        "scripts": [],
        "extractLicenses": false,
        "sourceMap": true,
        "optimization": false,
        "namedChunks": true,
        "browser": "apps/ng-x-rocket/src/main.ts",
        "stylePreprocessorOptions": {
          "includePaths": [".", "apps/ng-x-rocket"]
        }
      },
      "configurations": {
        "production": {
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "10kb"
            }
          ],
          "serviceWorker": "ngsw-config.json",
          "fileReplacements": [
            {
              "replace": "apps/ng-x-rocket/src/environments/environment.ts",
              "with": "apps/ng-x-rocket/src/environments/environment.prod.ts"
            }
          ]
        },
        "ci": {
          "progress": false
        }
      },
      "defaultConfiguration": "",
      "outputs": ["{options.outputPath.base}"]
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "buildTarget": "ng-x-rocket:build",
        "proxyConfig": "proxy.conf.js"
      },
      "configurations": {
        "production": {
          "buildTarget": "ng-x-rocket:build:production"
        },
        "ci": {}
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "ng-x-rocket:build"
      }
    },
    "test": {
      "executor": "@angular-builders/jest:run",
      "options": {
        "configPath": "jest.config.js",
        "rootDir": "apps/ng-x-rocket",
        "tsConfig": "tsconfig.spec.json",
        "watch": true
      },
      "configurations": {
        "ci": {
          "watch": false,
          "ci": true,
          "coverage": true,
          "silent": true
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/ng-x-rocket/**/*.ts", "apps/ng-x-rocket/**/*.html"]
      }
    }
  }
}
